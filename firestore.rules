rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidBooking(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.email is string && data.email.size() > 0 && data.email.size() <= 100
        && data.company is string && data.company.size() > 0 && data.company.size() <= 100
        && data.objective is string && data.objective.size() > 0 && data.objective.size() <= 100
        && (!data.keys().contains('notes') || (data.notes is string && data.notes.size() <= 1000))
        && data.createdAt == request.time;
    }

    match /bookings/{bookingId} {
      allow create: if isValidId(bookingId) 
        && incoming().keys().hasAll(['name', 'email', 'company', 'objective', 'createdAt'])
        && (incoming().keys().size() == 5 || (incoming().keys().size() == 6 && incoming().keys().contains('notes')))
        && isValidBooking(incoming());
      
      allow read: if isSignedIn();
      allow delete: if isSignedIn();
    }
  }
}
